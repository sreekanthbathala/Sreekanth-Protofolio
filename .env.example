# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_USER: The email address used to send contact form messages.
# EMAIL_PASS: The app password or password for the email account.
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
# CONTACT_RECEIVER: The email address that will receive the messages.
CONTACT_RECEIVER="sreekanthbathala8@gmail.com"
